{
  "expo": {
    "newArchEnabled": false,
    "name": "Street Nacho Personeel",
    "slug": "foodworks-staff-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "scheme": "foodworks-staff",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "Street Nacho gebruikt je locatie voor het inklokken op de werklocatie."
      }],
      ["expo-notifications", {
        "icon": "./assets/icon.png",
        "color": "#e78e89"
      }],
      ["expo-camera", {
        "cameraPermission": "Street Nacho heeft toegang tot je camera nodig voor het uploaden van bonnetjes."
      }],
      ["expo-image-picker", {
        "photosPermission": "Street Nacho heeft toegang tot je foto's nodig voor het uploaden van bonnetjes."
      }]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "nl.streetnacho.personeel"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAFA"
      },
      "package": "nl.streetnacho.personeel"
    }
  }
}
